# Template for .env.production. Unlike .env.development, the real
# .env.production is GITIGNORED and is NOT committed — production config is
# injected at build time by CI (GitHub Actions), from public repo *variables*
# (not secrets). This file only documents the expected shape.
#
# ⚠️ NOT FOR PROD: do NOT deploy production with the committed dev values in
# .env.development. Those point at the DEV API, DEV Cognito pool, and the Stripe
# TEST account — they are dev-only. Production uses its own values below.
#
# ⚠️ VITE_* vars are baked into the PUBLIC browser bundle. Never put a secret
# here: no sk_live_ keys, no whsec_ webhook secrets, no passwords, no AWS creds.
# Only URLs, IDs, and PUBLISHABLE keys (pk_live_) belong in a client build.
# Real secrets live server-side in AWS Secrets Manager and are read by the API.

# Must be live in production. `vite build` FAILS if this is 'mock' or if it is
# 'live' with no VITE_API_BASE_URL (see vite.config.ts / implementation.md §7).
VITE_API_MODE=live

# Deployed production API + WebSocket origins (prod stack not provisioned yet).
VITE_API_BASE_URL=
VITE_WS_URL=

# Production Cognito buyer pool + the website's PRODUCTION app client
# (a separate client from dev; never reuse the iOS/dashboard client IDs).
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# Stripe PUBLISHABLE key only (pk_live_...). Never the secret key.
VITE_STRIPE_PUBLISHABLE_KEY=

# Optional: pin the restaurant group; defaults to the first from GET /restaurants.
VITE_RESTAURANT_ID=
