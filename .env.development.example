# Copy to .env.development and fill in for live-API mode.
# With VITE_API_MODE=mock (the default when unset) the site runs fully offline
# against the bundled mock data — no AWS resources are touched.

# mock | live
VITE_API_MODE=mock

# Deidos Eats API base URL (dev). In `npm run dev` requests go through the
# Vite /api proxy to avoid CORS; this is the proxy target.
# e.g. https://<apiId>.execute-api.eu-west-1.amazonaws.com/dev
VITE_API_BASE_URL=

# API Gateway WebSocket endpoint for live order status.
# e.g. wss://<wsApiId>.execute-api.eu-west-1.amazonaws.com/dev
VITE_WS_URL=

# Cognito user pool (buyer auth). Same pool the iOS app uses.
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# Stripe publishable key (pk_test_... in dev).
VITE_STRIPE_PUBLISHABLE_KEY=

# Optional: pin the restaurant group; defaults to the first one returned by GET /restaurants.
VITE_RESTAURANT_ID=
