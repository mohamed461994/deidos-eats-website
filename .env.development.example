# Template for .env.development — but note the real .env.development is
# COMMITTED to this repo (public dev identifiers only, no secrets), so you
# normally don't need this file. The site runs in LIVE mode against the real
# dev API; mock mode is reserved for the unit-test harness (.env.test).

# live | mock — live is the default and the only supported mode for running
# the site (see implementation.md §0). Never set mock here.
VITE_API_MODE=live

# Deidos Eats API base URL (dev). In `npm run dev` requests go through the
# Vite /api proxy to avoid CORS; this is the proxy target.
# e.g. https://<apiId>.execute-api.eu-west-1.amazonaws.com/dev
VITE_API_BASE_URL=

# API Gateway WebSocket endpoint for live order status.
# e.g. wss://<wsApiId>.execute-api.eu-west-1.amazonaws.com/dev
VITE_WS_URL=

# Cognito buyer pool (shared with iOS) + the WEBSITE's own app client
# (never reuse the iOS or dashboard client IDs).
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# Stripe publishable key (pk_test_... in dev).
VITE_STRIPE_PUBLISHABLE_KEY=

# Optional: pin the restaurant group; defaults to the first one returned by GET /restaurants.
VITE_RESTAURANT_ID=
