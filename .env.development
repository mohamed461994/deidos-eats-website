# Public dev identifiers only — never commit secrets or passwords.
# Committed on purpose (same convention as the dashboard's .env.development):
# the website runs against the REAL dev API — the same backend, Cognito pool,
# and user data as the iOS app. Mock mode is for the unit-test harness only
# (see .env.test); do not switch this back to mock.
#
# ⚠️ DEV ONLY — NOT FOR PRODUCTION DEPLOYMENT. Every value below points at the
# DEV account (dev API/WS, dev Cognito pool, Stripe TEST key). Never deploy prod
# with this file. Production config is injected by CI into .env.production
# (gitignored; template in .env.production.example) — see implementation.md §7.

VITE_API_MODE=live

# Deidos Eats dev API. In `npm run dev` the browser calls the Vite /api proxy
# (same-origin, avoids CORS) which forwards to this URL.
VITE_API_BASE_URL=https://izio5wfs4g.execute-api.eu-west-1.amazonaws.com/dev

# API Gateway WebSocket endpoint for live order status (dev).
VITE_WS_URL=wss://s65u292zxd.execute-api.eu-west-1.amazonaws.com/dev

# Buyer Cognito pool (shared with iOS) + the website's own app client.
# Never reuse the iOS or dashboard client IDs.
VITE_COGNITO_USER_POOL_ID=eu-west-1_iah1mG6kG
VITE_COGNITO_CLIENT_ID=4033eub2av4ulr8mi32gu2evhv

# Public, unlinked staff-entry path. This is only a noise reducer; Cognito MFA and API authz
# are the security boundary. Keep it out of buyer chrome and sitemaps.
VITE_STAFF_SIGN_IN_PATH=/access/hall-47

# Stripe publishable key (test mode) — same key iOS dev uses. Public by design.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_51TjmgMDJtx90rYI3kZcflO8lH3Ft1R7sG3FQMlao14mb8PESo2hRRUzSa3VuCqxzNIzdKegw9WUEuCbzMsvBh6oF00p1g6MAVh

# Optional: pin the restaurant group; defaults to the first one from GET /restaurants.
VITE_RESTAURANT_ID=
